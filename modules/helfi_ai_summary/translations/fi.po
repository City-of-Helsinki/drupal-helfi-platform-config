msgctxt "helfi_ai_summary"
msgid "AI summary"
msgstr "Tekoälytiivistelmä"

msgctxt "helfi_ai_summary"
msgid "AI-generated content summary as a bullet list. Edit before accepting."
msgstr "Tekoälyn luoma tiivistelmä bullet-listana. Voit muokata ennen hyväksymistä."

msgctxt "helfi_ai_summary"
msgid "Generate AI summary"
msgstr "Luo tekoälytiivistelmä"

msgctxt "helfi_ai_summary"
msgid "Regenerate AI summary"
msgstr "Luo tekoälytiivistelmä uudelleen"

msgctxt "helfi_ai_summary"
msgid "Accept"
msgstr "Hyväksy"

msgctxt "helfi_ai_summary"
msgid "Reject"
msgstr "Hylkää"

msgctxt "helfi_ai_summary"
msgid "AI is creating a summary…"
msgstr "Tekoäly luo tiivistelmää…"

msgctxt "helfi_ai_summary"
msgid "AI generates a 4–6 bullet point summary of the page. You can edit the summary before accepting."
msgstr "Tekoäly luo sivusta 4–6 bullet-pisteen tiivistelmän. Voit muokata tiivistelmää ennen hyväksymistä."

msgctxt "helfi_ai_summary"
msgid "You can edit the text before accepting."
msgstr "Voit muokata tekstiä ennen hyväksymistä."

msgctxt "helfi_ai_summary"
msgid "The summary is saved with the page. You can create a new suggestion at any time."
msgstr "Tiivistelmä tallennetaan sivun mukana. Voit luoda uuden ehdotuksen milloin tahansa."

msgctxt "helfi_ai_summary"
msgid "Could not generate summary. Ensure the content is saved and the AI provider is configured."
msgstr "Tiivistelmän luominen epäonnistui. Varmista, että sisältö on tallennettu ja tekoälypalvelu on määritelty."
