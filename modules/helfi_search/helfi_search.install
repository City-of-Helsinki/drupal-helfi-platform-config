<?php

/**
 * @file
 * Install hooks for the helfi_search module.
 */

declare(strict_types=1);

use Drupal\helfi_search\OpenAI\EmbeddingsApi;
use Drupal\language\ConfigurableLanguageManagerInterface;
use Drupal\search_api\Entity\Index;

/**
 * Implements hook_schema().
 *
 * @phpstan-return array<string, mixed>
 */
function helfi_search_schema(): array {
  $schema = [];

  $schema['helfi_search_token_usage'] = [
    'description' => 'Tracks token usage for OpenAI models.',
    'fields' => [
      'model_name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'The model name.',
      ],
      'total_tokens' => [
        'type' => 'int',
        'size' => 'big',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Total tokens consumed by this model.',
      ],
    ],
    'primary key' => ['model_name'],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function helfi_search_install(bool $is_syncing): void {
  // Do not perform following steps if the module is being installed as part
  // of a configuration import.
  if ($is_syncing) {
    return;
  }

  // Enable etusivu search_api server.
  $config_factory = \Drupal::configFactory();
  $etusivu_server_settings = $config_factory->getEditable('search_api.server.etusivu');
  if ($etusivu_server_settings->get('status') === FALSE) {
    $etusivu_server_settings
      ->set('status', TRUE)
      ->save();
  }
}

/**
 * Update the embeddings index datasources and enable multisite option.
 */
function helfi_search_update_8001(): void {
  $config = \Drupal::configFactory()->getEditable('search_api.index.embeddings');

  // Do not run the update if the config didn't exist yet.
  if ($config->isNew()) {
    return;
  }

  // Change all uuid-datasources to regular entity datasources.
  $datasource_settings = $config->get('datasource_settings');
  foreach ($datasource_settings as $datasource_id => $datasource_setting_value) {
    if (str_starts_with($datasource_id, 'uuid_entity:')) {
      $new_datasource_id = str_replace('uuid_entity:', 'entity:', $datasource_id);
      $datasource_settings[$new_datasource_id] = $datasource_setting_value;
      unset($datasource_settings[$datasource_id]);
    }
  }
  $config->set('datasource_settings', $datasource_settings);

  // Enable multisite option.
  $options = $config->get('options');
  $options['helfi_platform_config_multisite'] = TRUE;
  $config->set('options', $options);

  $config->save();
}

/**
 * Update embeddings index fields.
 */
function helfi_search_update_8002(): void {
  $config = \Drupal::configFactory()->getEditable('search_api.index.embeddings');

  // Do not run the update if the config didn't exist yet.
  if ($config->isNew()) {
    return;
  }

  // Update fields that are still trying to use the old uuid_entity datasource.
  $field_settings = $config->get('field_settings');
  foreach ($field_settings as $field_id => $field_value) {
    if (isset($field_value['datasource_id']) && str_starts_with($field_value['datasource_id'], 'uuid_entity:')) {
      $field_settings[$field_id]['datasource_id'] = str_replace('uuid_entity:', 'entity:', $field_value['datasource_id']);
    }
  }
  $config->set('field_settings', $field_settings);

  $config->save();
}

/**
 * Add new processors and TPR datasources to the embeddings index.
 */
function helfi_search_update_11000(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  $moduleHandler = \Drupal::moduleHandler();
  /** @var \Drupal\search_api\Utility\PluginHelperInterface $pluginHelper */
  $pluginHelper = \Drupal::service('search_api.plugin_helper');

  // Add TPR datasources if helfi_tpr module is installed.
  if ($moduleHandler->moduleExists('helfi_tpr')) {
    $tpr_datasources = ['entity:tpr_service', 'entity:tpr_unit'];

    foreach ($tpr_datasources as $datasource_id) {
      if (!$index->isValidDatasource($datasource_id)) {
        $datasource = $pluginHelper->createDatasourcePlugin($index, $datasource_id);
        $index->addDatasource($datasource);
      }
    }
  }

  $index->save();
}

/**
 * Replace node-specific title field with entity label processor field.
 */
function helfi_search_update_11001(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  // Remove the old node-specific title field.
  if ($index->getField('title')) {
    $index->removeField('title');
  }

  // Add the entity label field backed by the new processor.
  if (!$index->getField('label')) {
    /** @var \Drupal\search_api\Utility\PluginHelperInterface $pluginHelper */
    $pluginHelper = \Drupal::service('search_api.plugin_helper');

    // Enable the helfi_entity_label processor.
    if (!$index->isValidProcessor('helfi_entity_label')) {
      $processor = $pluginHelper->createProcessorPlugin($index, 'helfi_entity_label');
      $index->addProcessor($processor);
    }

    $field = \Drupal::getContainer()
      ->get('search_api.fields_helper')
      ->createField($index, 'label', [
        'label' => 'Entity label',
        'property_path' => 'helfi_entity_label',
        'type' => 'string',
      ]);
    $index->addField($field);
  }

  $index->save();
}

/**
 * Decrease embeddings index batch size per cron run.
 */
function helfi_search_update_11002(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  $index->setOption('cron_limit', 1);
  $index->save();
}

/**
 * Enable both OpenAI v3 embedding models and add pricing to config.
 */
function helfi_search_update_11003(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');

  $config->set('openai_models', [
    'text-embedding-3-small',
    'text-embedding-3-large',
  ]);

  $config->set('openai_model_pricing', [
    'text-embedding-3-small' => 0.02,
    'text-embedding-3-large' => 0.13,
  ]);

  $config->save();
}

/**
 * Increase embeddings index batch size per cron run.
 */
function helfi_search_update_11004(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  $index->setOption('cron_limit', 5);
  $index->save();
}

/**
 * Add embeddings processor fields to the embeddings index.
 */
function helfi_search_update_11005(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  /** @var \Drupal\search_api\Utility\PluginHelperInterface $pluginHelper */
  $pluginHelper = \Drupal::service('search_api.plugin_helper');

  // Enable the embeddings processor if not already present.
  if (!$index->isValidProcessor('helfi_search_embeddings')) {
    $processor = $pluginHelper->createProcessorPlugin($index, 'helfi_search_embeddings');
    $index->addProcessor($processor);
  }

  // Add a field for each configured model.
  $models = \Drupal::config('helfi_search.settings')->get('openai_models') ?? [];
  $fieldsHelper = \Drupal::getContainer()->get('search_api.fields_helper');

  foreach ($models as $model) {
    $suffix = EmbeddingsApi::sanitizeModelName($model);
    $fieldName = 'embeddings_' . $suffix;

    if ($index->getField($fieldName)) {
      continue;
    }

    $field = $fieldsHelper->createField($index, $fieldName, [
      'label' => "Embeddings ($model)",
      'property_path' => $fieldName,
      'type' => 'embeddings',
    ]);
    $index->addField($field);
  }

  $index->save();
}

/**
 * Add entity bundle field to the embeddings index.
 */
function helfi_search_update_11006(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  if ($index->getField('entity_bundle')) {
    return;
  }

  $field = \Drupal::getContainer()
    ->get('search_api.fields_helper')
    ->createField($index, 'entity_bundle', [
      'label' => 'Entity bundle',
      'property_path' => 'helfi_entity_bundle',
      'type' => 'string',
    ]);
  $index->addField($field);
  $index->save();
}

/**
 * Drop the small embeddings model in favour of the large one.
 */
function helfi_search_update_11007(): void {
  $removed = 'text-embedding-3-small';

  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');

  $models = $config->get('openai_models') ?? [];
  $models = array_values(array_filter($models, fn ($m) => $m !== $removed));
  $config->set('openai_models', $models);
}

/**
 * Set defaults for the semantic-search options.
 */
function helfi_search_update_11008(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');

  if ($config->get('deboost_bundles') === NULL) {
    $config->set('deboost_bundles', ['news_article', 'news_item']);
  }
  if ($config->get('deboost_factor') === NULL) {
    $config->set('deboost_factor', 0.9);
  }
  if ($config->get('min_score') === NULL) {
    $config->set('min_score', 0.36);
  }

  $config->save();
}

/**
 * Add publication_date field to the embeddings index.
 */
function helfi_search_update_11009(): void {
  if (!\Drupal::moduleHandler()->moduleExists('publication_date')) {
    return;
  }

  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  if ($index->getField('published_at')) {
    return;
  }

  $field = \Drupal::service('search_api.fields_helper')
    ->createField($index, 'published_at', [
      'label' => 'Published',
      'datasource_id' => 'entity:node',
      'property_path' => 'published_at',
      'type' => 'date',
    ]);
  $index->addField($field);
  $index->save();
}

/**
 * Seed ignored_classes config with the previous hard-coded list.
 */
function helfi_search_update_11010(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');

  if ($config->get('ignored_classes') !== NULL) {
    return;
  }

  $config->set('ignored_classes', [
    'is-hidden',
    'visually-hidden',
    'skip-link',
    'table-of-contents',
    'component--recommendations',
    'component--map',
    'component--hearings',
    'announcement',
    'content-tags',
    'content-date',
    'content-links',
    'block--askem',
  ]);

  $config->save();
}

/**
 * Add the "Helsinki near you" external search link with per-language URLs.
 */
function helfi_search_update_11011(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');
  $external_links = $config->get('external_links') ?? [];

  if (!isset($external_links['helsinki_near_you'])) {
    $external_links['helsinki_near_you'] = 'https://www.hel.fi/en/helsinki-near-you';
    $config->set('external_links', $external_links);
    $config->save();
  }

  $overrides = [
    'fi' => 'https://www.hel.fi/fi/helsinki-lahellasi',
    'sv' => 'https://www.hel.fi/sv/helsingfors-nara-dig',
  ];

  $languageManager = \Drupal::languageManager();
  foreach ($overrides as $langcode => $url) {
    assert($languageManager instanceof ConfigurableLanguageManagerInterface);
    $override = $languageManager->getLanguageConfigOverride($langcode, 'helfi_search.settings');
    $links = $override->get('external_links') ?? [];
    if (isset($links['helsinki_near_you'])) {
      continue;
    }
    $links['helsinki_near_you'] = $url;
    $override->set('external_links', $links)->save();
  }
}
