<?php

/**
 * @file
 * Install hooks for the helfi_search module.
 */

declare(strict_types=1);

use Drupal\language\ConfigurableLanguageManagerInterface;
use Drupal\search_api\Entity\Index;
use Drupal\search_api\Item\Field;

/**
 * Implements hook_schema().
 *
 * @phpstan-return array<string, mixed>
 */
function helfi_search_schema(): array {
  $schema = [];

  $schema['helfi_search_token_usage'] = [
    'description' => 'Tracks token usage for OpenAI models.',
    'fields' => [
      'model_name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'The model name.',
      ],
      'total_tokens' => [
        'type' => 'int',
        'size' => 'big',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Total tokens consumed by this model.',
      ],
    ],
    'primary key' => ['model_name'],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function helfi_search_install(bool $is_syncing): void {
  // Do not perform following steps if the module is being installed as part
  // of a configuration import.
  if ($is_syncing) {
    return;
  }

  // Enable etusivu search_api server.
  $config_factory = \Drupal::configFactory();
  $etusivu_server_settings = $config_factory->getEditable('search_api.server.etusivu');
  if ($etusivu_server_settings->get('status') === FALSE) {
    $etusivu_server_settings
      ->set('status', TRUE)
      ->save();
  }
}

/**
 * Seed ignored_classes config with the previous hard-coded list.
 */
function helfi_search_update_11010(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');

  if ($config->get('ignored_classes') !== NULL) {
    return;
  }

  $config->set('ignored_classes', [
    'is-hidden',
    'visually-hidden',
    'skip-link',
    'table-of-contents',
    'component--recommendations',
    'component--map',
    'component--hearings',
    'announcement',
    'content-tags',
    'content-date',
    'content-links',
    'block--askem',
  ]);

  $config->save();
}

/**
 * Add the "Helsinki near you" external search link with per-language URLs.
 */
function helfi_search_update_11011(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');
  $external_links = $config->get('external_links') ?? [];

  if (!isset($external_links['helsinki_near_you'])) {
    $external_links['helsinki_near_you'] = 'https://www.hel.fi/en/helsinki-near-you';
    $config->set('external_links', $external_links);
    $config->save();
  }

  $overrides = [
    'fi' => 'https://www.hel.fi/fi/helsinki-lahellasi',
    'sv' => 'https://www.hel.fi/sv/helsingfors-nara-dig',
  ];

  $languageManager = \Drupal::languageManager();
  foreach ($overrides as $langcode => $url) {
    assert($languageManager instanceof ConfigurableLanguageManagerInterface);
    $override = $languageManager->getLanguageConfigOverride($langcode, 'helfi_search.settings');
    $links = $override->get('external_links') ?? [];
    if (isset($links['helsinki_near_you'])) {
      continue;
    }
    $links['helsinki_near_you'] = $url;
    $override->set('external_links', $links)->save();
  }
}

/**
 * Add remote-video to ignored_classes config.
 */
function helfi_search_update_11012(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');
  $ignored_classes = $config->get('ignored_classes') ?? [];

  if (in_array('remote-video', $ignored_classes, TRUE)) {
    return;
  }

  $ignored_classes[] = 'remote-video';
  $ignored_classes[] = 'views--unit-search';
  $config->set('ignored_classes', $ignored_classes)->save();
}

/**
 * Add OmaStadi to canonical_terms.
 */
function helfi_search_update_11013(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');
  $terms = $config->get('canonical_terms') ?? [];

  if (in_array('OmaStadi', $terms, TRUE)) {
    return;
  }

  $terms[] = 'OmaStadi';
  $config->set('canonical_terms', $terms)->save();
}

/**
 * Clear `openai_models` config key.
 */
function helfi_search_update_11014(): void {
  // Model config was useless. Moved the feature to EmbeddingModel enum.
  \Drupal::configFactory()
    ->getEditable('helfi_search.settings')
    ->clear('openai_models')
    ->save();
}

/**
 * Add the metatag title field to the embeddings index.
 */
function helfi_search_update_11015(): void {
  // The metatag title processor is only available when metatag is installed.
  if (!\Drupal::moduleHandler()->moduleExists('metatag')) {
    return;
  }

  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  $plugin_helper = \Drupal::service('search_api.plugin_helper');
  $changed = FALSE;

  // The field is populated by the metatag title processor, so make sure it is
  // enabled on the index.
  if (!$index->isValidProcessor('helfi_metatag_title')) {
    $index->addProcessor(
      $plugin_helper->createProcessorPlugin($index, 'helfi_metatag_title')
    );
    $changed = TRUE;
  }

  if (!$index->getField('metatag_title')) {
    $field = (new Field($index, 'metatag_title'))
      ->setType('string')
      ->setPropertyPath('helfi_metatag_title')
      ->setLabel('Metatag title');
    $index->addField($field);
    $changed = TRUE;
  }

  if ($changed) {
    $index->save();
  }
}

/**
 * Add component--list-of-links to ignored_classes config.
 */
function helfi_search_update_11016(): void {
  $config = \Drupal::configFactory()->getEditable('helfi_search.settings');
  $ignored_classes = $config->get('ignored_classes') ?? [];

  if (in_array('component--list-of-links', $ignored_classes, TRUE)) {
    return;
  }

  $ignored_classes[] = 'component--list-of-links';
  $config->set('ignored_classes', $ignored_classes)->save();
}

/**
 * Add the metatag noindex processor to the embeddings index.
 */
function helfi_search_update_11017(): void {
  $index = Index::load('embeddings');

  if (!$index) {
    return;
  }

  // Exclude entities that have the robots "noindex" metatag set from being
  // indexed.
  if (!$index->isValidProcessor('helfi_metatag_noindex')) {
    $plugin_helper = \Drupal::service('search_api.plugin_helper');
    $index->addProcessor(
      $plugin_helper->createProcessorPlugin($index, 'helfi_metatag_noindex')
    );
    $index->save();
  }
}
