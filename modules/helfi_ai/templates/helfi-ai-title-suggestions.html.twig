<div class="helfi-ai-suggestions">
  <fieldset class="helfi-ai-suggestions__options">
    <legend class="visually-hidden">{{ 'Suggested titles'|t({}, {'context': 'helfi_ai'}) }}</legend>
    {% for suggestion in suggestions %}
      {% set id = 'helfi-ai-suggestions__option-' ~ loop.index0 %}
      <div class="form-item form-type--radio form-type--boolean helfi-ai-suggestions__option">
        <input
          type="radio"
          name="helfi_ai_title"
          id="{{ id }}"
          class="form-radio form-boolean form-boolean--type-radio helfi-ai-suggestions__radio"
          value="{{ suggestion }}"
          {{ loop.first ? 'checked' }}
        />
        <label for="{{ id }}" class="form-item__label option helfi-ai-suggestions__label">
          {{ suggestion }} <span class="helfi-ai-suggestions__count">({{ suggestion|length }} {{ 'characters'|t({}, {'context': 'helfi_ai'}) }})</span>
        </label>
      </div>
    {% endfor %}
  </fieldset>
  <div class="form-actions helfi-ai-suggestions__actions">
    <button type="button" class="button button--primary helfi-ai-suggestions__apply">{{ 'Apply'|t({}, {'context': 'helfi_ai'}) }}</button>
    <button type="button" class="button button--secondary helfi-ai-suggestions__cancel">{{ 'Cancel'|t({}, {'context': 'helfi_ai'}) }}</button>
  </div>
</div>
