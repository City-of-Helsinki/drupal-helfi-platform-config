<?php

/**
 * @file
 * Contains helfi_ai module hooks.
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Field\BaseFieldDefinition;
use Drupal\Core\Form\FormStateInterface;
use Drupal\helfi_ai\Form\TitleSuggestionFormAlter;

/**
 * Implements hook_entity_base_field_info().
 *
 * @phpstan-return array<string, \Drupal\Core\Field\BaseFieldDefinition>
 */
function helfi_ai_entity_base_field_info(EntityTypeInterface $entity_type): array {
  if ($entity_type->id() !== 'node') {
    return [];
  }

  $fields['field_ai_summary'] = BaseFieldDefinition::create('text_long')
    ->setLabel(t('AI summary', options: ['context' => 'helfi_ai']))
    ->setDescription(t('AI-generated content summary as a bullet list. Edit before accepting.', options: ['context' => 'helfi_ai']))
    ->setRevisionable(TRUE)
    ->setTranslatable(TRUE)
    ->setDisplayConfigurable('form', TRUE)
    ->setDisplayConfigurable('view', TRUE);

  return $fields;
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 *
 * Adds the AI "Suggest SEO title" button next to the title field on the
 * supported content types.
 */
function helfi_ai_form_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  TitleSuggestionFormAlter::alter($form, $form_state);
}
